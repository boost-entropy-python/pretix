msgid "Start of validity"
msgstr "Bắt đầu hiệu lực"

#: pretix/base/models/items.py
msgid "End of validity"
msgstr "Kết thúc hiệu lực"

#: pretix/base/models/items.py
msgid "Minutes"
msgstr "phút"

#: pretix/base/models/items.py
msgid "Hours"
