#: pretix/plugins/stripe/apps.py
msgid ""
"Accept payments via Stripe, a globally popular payment service provider. "
"Stripe supports payments via credit cards as well as many local payment "
"methods such as iDEAL, Alipay,and many more."
msgstr ""
"Hyväksy maksuja Stripen kautta, joka on maailmanlaajuisesti suosittu "
"maksupalveluntarjoaja. Stripe tukee maksuja luottokorteilla sekä monia "
"paikallisia maksutapoja, kuten iDEAL, Alipay ja monet muut."

#: pretix/plugins/stripe/forms.py
#, python-format
