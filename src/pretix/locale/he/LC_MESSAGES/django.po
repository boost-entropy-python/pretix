msgid "John Doe"
msgstr "ג'ון דו"

#: pretix/base/settings.py
msgid "Calling name"
msgstr "שם בו פונים אליך"

#: pretix/base/settings.py
msgid "Latin transcription"
msgstr "תעתיק לטיני"

#: pretix/base/settings.py
msgctxt "person_name"
msgid "Salutation"
msgstr "ברכה/פניה"

#: pretix/base/settings.py
