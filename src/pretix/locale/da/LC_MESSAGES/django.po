msgstr "Ethvert land"

#: pretix/control/forms/event.py
msgid "European Union"
msgstr "Den Europæiske Union"

#: pretix/control/forms/event.py
msgid "Any customer"
msgstr "Enhver kunde"

#: pretix/control/forms/event.py
msgid "Individual"
msgstr "Individuel"

#: pretix/control/forms/event.py
