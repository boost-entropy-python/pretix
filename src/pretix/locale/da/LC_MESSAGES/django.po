msgstr "Udfyldt ikke hvis der skal være et ubegrænset antal billetter."

#: pretix/base/models/items.py pretix/base/models/orders.py
#: pretix/control/templates/pretixcontrol/checkin/index.html
msgid "Item"
msgstr "Element"

#: pretix/base/models/items.py pretix/control/forms/item.py
#: pretix/plugins/autocheckin/models.py
