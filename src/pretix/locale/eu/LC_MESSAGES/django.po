"gabe, baina PayPal-en sandbox-aren erabiltzaile bat beharko duzu saioa "
"hasteko."

#: pretix/plugins/paypal/payment.py
msgid "PayPal account"
msgstr "PayPal kontua"

#: pretix/plugins/paypal/payment.py pretix/plugins/paypal2/payment.py
#, python-brace-format
