#: pretix/base/models/tax.py
msgctxt "invoice"
msgid ""
"Reverse Charge: According to Article 194, 196 of Council Directive 2006/112/"
"EEC, VAT liability rests with the service recipient."
msgstr ""
"Fordított adózás: A 2006/112/EK tanácsi irányelv 194. és 196. cikke alapján "
"az ÁFA fizetésére a szolgáltatás igénybevevője kötelezett."

#: pretix/base/models/tax.py
msgctxt "invoice"
msgid "VAT liability rests with the service recipient."
