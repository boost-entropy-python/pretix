msgstr "Beállítás alapértelmezettként"

#: pretix/control/templates/pretixcontrol/event/tax.html
#, python-format
msgid "%(count)s product"
msgid_plural "%(count)s products"
msgstr[0] "%(count)s termék"
msgstr[1] "%(count)s termék"

#: pretix/control/templates/pretixcontrol/event/tax.html
