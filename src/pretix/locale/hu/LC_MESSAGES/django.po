msgid "The product \"{}\" is not assigned to a quota."
msgstr "\"{}\" termékhez nincs kvóta rendelve."

#: pretix/api/serializers/checkin.py pretix/base/models/event.py
#: pretix/base/models/items.py
msgid "One or more items do not belong to this event."
msgstr "Egy vagy több tétel nem ehhez az eseményhez tartozik."

#: pretix/api/serializers/checkin.py pretix/base/models/items.py
#: pretix/base/models/waitinglist.py
msgid "The subevent does not belong to this event."
msgstr "A részesemény nem ehhez az eseményhez tartozik."

#: pretix/api/serializers/event.py
msgid ""
"Events cannot be created as 'live'. Quotas and payment must be added to the "
"event before sales can go live."
msgstr ""
"Az eseményt nem lehet \"élő\"-ként létrehozni. A kvóták és fizetés "
"hozzáadása kötelező az eseményhez, az értékesítés megkezdése előtt."

#: pretix/api/serializers/event.py
#, python-brace-format
msgid "Meta data property '{name}' does not exist."
msgstr "A {name} meta adat tulajdonság nem létezik."

#: pretix/api/serializers/event.py
#, python-brace-format
msgid "Meta data property '{name}' does not allow value '{value}'."
msgstr "A {name} meta adat értéke nem lehet {value}."

#: pretix/api/serializers/event.py pretix/api/serializers/organizer.py
#, python-brace-format
msgid "Unknown plugin: '{name}'."
msgstr "Ismeretlen plugin: '{name}'."

#: pretix/api/serializers/event.py pretix/api/serializers/organizer.py
#, python-brace-format
msgid "Restricted plugin: '{name}'."
msgstr "Korlátozott plugin: '{name}'."

#: pretix/api/serializers/item.py
#, python-brace-format
msgid "Item meta data property '{name}' does not exist."
msgstr "A {name} elem meta adat tulajdonság nem létezik."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "The bundled item must not be the same item as the bundling one."
msgstr "A csomag-termék nem lehet azonos a csomagba való termékkel."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "The bundled item must not have bundles on its own."
msgstr "A csomag-termék nem tartalmazhat csomagokat."

#: pretix/api/serializers/item.py
msgid "The program start must not be empty."
msgstr "Az esemény kezdete nem lehet üres."

#: pretix/api/serializers/item.py
msgid "The program end must not be empty."
msgstr "Az esemény vége nem lehet üres."

#: pretix/api/serializers/item.py pretix/base/models/items.py
msgid "The program end must not be before the program start."
msgstr "A program vége időpont nem lehet a kezdő időpont előtt."

#: pretix/api/serializers/item.py pretix/base/models/items.py
msgid "You cannot use program times on an event series."
msgstr "Nem jelölhetsz időpontokat eseménysorozathoz."

#: pretix/api/serializers/item.py
msgid ""
"Updating add-ons, bundles, program times or variations via PATCH/PUT is not "
"supported. Please use the dedicated nested endpoint."
msgstr ""
"A kiegészítők, csomagok, időpontok vagy variációk frissítése PATCH/PUT "
"használatával nem támogatott. Kérem használja a dedikált beágyazott "
"végpontot."

#: pretix/api/serializers/item.py
msgid "Only admission products can currently be personalized."
msgstr "Jelenleg csak a belépési termékeket lehet személyre szabni."

#: pretix/api/serializers/item.py
msgid ""
"Gift card products should not be associated with non-zero tax rates since "
"sales tax will be applied when the gift card is redeemed."
msgstr ""
"Ajándékkártya termékeket nem lehet nem-nulla adókulcshoz kapcsolni, mivel az "
"ajándékkártya beváltásakor az ÁFA alkalmazva lesz."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "Gift card products should not be admission products at the same time."
msgstr "Ajándékkártya termékek nem lehetnek egyszerre belépési termékek is."

#: pretix/api/serializers/item.py
msgid ""
"Updating options via PATCH/PUT is not supported. Please use the dedicated "
"nested endpoint."
msgstr ""
"Az opciók frissítése PATCH/PUT használatával nem támogatott. Kérem használja "
"a dedikált beágyazott végpontot."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "Question cannot depend on a question asked during check-in."
msgstr "A kérdés nem függhet a becsekkolás során kérdezett kérdésen."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "Circular dependency between questions detected."
msgstr "Körkörös függőség észlelve a kérdések között."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "This type of question cannot be asked during check-in."
msgstr "Ezt a fajta kérdést nem lehet kérdezni becsekkolás közben."

#: pretix/api/serializers/item.py pretix/control/forms/item.py
msgid "This type of question cannot be shown during check-in."
msgstr "Ezt a fajta kérdést nem lehet megmutatni becsekkolás közben."

#: pretix/api/serializers/media.py
msgid ""
"A medium with the same identifier and type already exists in your organizer "
"account."
msgstr "Már létező médium (azonos azonosító és típus)."

#: pretix/api/serializers/order.py
#, python-brace-format
msgid "\"{input}\" is not a valid choice."
msgstr "\"{input}\" nem választható."

