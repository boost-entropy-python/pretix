msgstr "Felülírás"

#: pretix/control/forms/mapping.py
msgid "Fill if new"
msgstr "Kitöltés, ha új"

#: pretix/control/forms/mapping.py
msgid "Fill if empty"
msgstr "Kitöltés, ha üres"

#: pretix/control/forms/mapping.py
