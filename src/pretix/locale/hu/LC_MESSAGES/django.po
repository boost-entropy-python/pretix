msgid "Event series date changed"
msgstr "Eseménysorozat időpontja megváltozott"

#: pretix/api/webhooks.py
msgctxt "subevent"
msgid "Event series date deleted"
msgstr "Eseménysorozat időpontja törölve"

#: pretix/api/webhooks.py
msgid "Product changed"
msgstr "Termék megváltozott"

#: pretix/api/webhooks.py
msgid ""
"This includes product added or deleted and changes to nested objects like "
"variations or bundles."
msgstr ""
"Ez magában foglalja a termékek hozzáadását vagy törlését, valamint a "
"beágyazott objektumok (például termékváltozatok vagy csomagok) módosítását."

#: pretix/api/webhooks.py
msgid "Quota changed"
msgstr "Kvóta megváltozott"

#: pretix/api/webhooks.py
msgid ""
"This includes related events like creation, deletion, opening or closing of "
"quotas. No webhook is sent for changes to the resulting availability."
msgstr ""
"Ide tartoznak a kapcsolódó események, például kvóták létrehozása, törlése, "
"megnyitása vagy lezárása. Az ebből eredő elérhetőségváltozásokról nem kerül "
"sor webhook küldésére."

#: pretix/api/webhooks.py
msgid "Shop taken live"
msgstr "Shop élesítve"

#: pretix/api/webhooks.py
msgid "Shop taken offline"
msgstr "Shop leállítva"

#: pretix/api/webhooks.py
msgid "Test-Mode of shop has been activated"
msgstr "A shop tesztmódja aktiválva lett"

#: pretix/api/webhooks.py
msgid "Test-Mode of shop has been deactivated"
msgstr "A shop tesztmódja deaktiválva lett"

#: pretix/api/webhooks.py
msgid "Waiting list entry added"
msgstr "Várólista-bejegyzés hozzáadva"

#: pretix/api/webhooks.py
msgid "Waiting list entry changed"
msgstr "A várólista eleme megváltozott"

#: pretix/api/webhooks.py
msgid "Waiting list entry deleted"
msgstr "A várólista eleme törlésre került"

#: pretix/api/webhooks.py
msgid "Waiting list entry received voucher"
msgstr "A várólista eleme kupont kapott"

#: pretix/api/webhooks.py
msgid "Voucher added"
msgstr "Kuponkód hozzáadásra került"

#: pretix/api/webhooks.py
msgid "Voucher changed"
msgstr "Kuponkód megváltozott"

#: pretix/api/webhooks.py
msgid ""
"Only includes explicit changes to the voucher, not e.g. an increase of the "
"number of redemptions."
msgstr ""
"Csak a kupon kifejezett módosításait tartalmazza, nem pedig például a "
"beváltások számának növekedését."

#: pretix/api/webhooks.py
msgid "Voucher deleted"
msgstr "Kuponkód törölve"

#: pretix/api/webhooks.py
