msgstr "\"{}\" termékhnem elérhető ezen a dátumon."

#: pretix/api/serializers/order.py pretix/api/views/cart.py
#, python-brace-format
msgid ""
"There is not enough quota available on quota \"{}\" to perform the operation."
msgstr "Nem áll elegendő \"{}\" kvóta rendelkezésre a művelet végrehajtásához."

#: pretix/api/serializers/organizer.py pretix/control/forms/organizer.py
#: pretix/presale/forms/customer.py
msgid "An account with this email address is already registered."
msgstr "Ezzel az email címmel már létezik regisztráció."

#: pretix/api/serializers/organizer.py pretix/control/forms/organizer.py
msgid ""
"A gift card with the same secret already exists in your or an affiliated "
"organizer account."
msgstr "Ezzel a titkos kulccsal már létezik ajándékkártya."

#: pretix/api/serializers/organizer.py pretix/control/views/organizer.py
#, python-format
msgid "You've been invited to join %(organizer)s"
msgstr "Önt meghívták a %(organizer)s szervezői csapatába"

#: pretix/api/serializers/organizer.py pretix/control/views/organizer.py
msgid "This user already has been invited for this team."
msgstr "Ez a felhasználó már meghívásra került ebbe a csoportba."

#: pretix/api/serializers/organizer.py pretix/control/views/organizer.py
msgid "This user already has permissions for this team."
msgstr "A felhasználó már rendelkezik hozzáféréssel."

#: pretix/api/views/cart.py
msgid ""
"The specified voucher has already been used the maximum number of times."
msgstr "A kupon elérte a felhasználhatóságának felső határát."

#: pretix/api/views/checkin.py
msgid "Medium connected to other event"
msgstr "A médium rendezvényhez csatlakoztatása megtörtént"

#: pretix/api/views/checkin.py
msgid "You cannot exchange a medium for a medium."
msgstr "Nem cserélhet adathordozót adathordozóra."

#: pretix/api/views/oauth.py pretix/control/logdisplay.py
#, python-brace-format
msgid ""
"The application \"{application_name}\" has been authorized to access your "
"account."
msgstr ""
"A(z) \"{application_name}\" applikáció mostantól eléréssel rendelkezik a "
"fiókodhoz."

#: pretix/api/views/order.py pretix/control/views/orders.py
#: pretix/presale/views/order.py
msgid "You cannot generate an invoice for this order."
msgstr "Ehhez a megrendeléshez nem készíthető számla."

#: pretix/api/views/order.py pretix/control/views/orders.py
#: pretix/presale/views/order.py
msgid "An invoice for this order already exists."
msgstr "Ehhez a megrendeléshez már készült számla."

#: pretix/api/views/order.py pretix/base/services/cart.py
#: pretix/base/services/orders.py pretix/presale/views/order.py
msgid "One of the selected products is not available in the selected country."
msgstr "Valameny kiválasztott termék nem elérhető a bejelölt országban."

