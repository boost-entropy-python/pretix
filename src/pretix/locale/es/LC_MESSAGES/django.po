msgstr "Todos los pedidos"

#: pretix/control/forms/filter.py
msgid "Valid orders"
msgstr "Pedidos válidos"

#: pretix/control/forms/filter.py
msgid "Paid (or canceled with paid fee)"
msgstr "Pagado (o cancelado con impuestos pagados)"

