msgstr ""
"Se deben responder las siguientes preguntas antes de poder completar el "
"check-in:"

#: pretix/control/templates/pretixcontrol/checkin/simulator.html
msgid "Media exchange required"
msgstr "Es necesario intercambiar medios"

